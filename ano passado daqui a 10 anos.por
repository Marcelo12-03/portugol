programa {
  funcao inicio() {

cadeia Nome

inteiro Valor1, Valor2, Resultado1, Resultado2

escreva ("Digite seu nome: ")
leia (Nome)
escreva ("Digite seu ano de nacimento")
leia (Valor1)
escreva ("Digite o ano de hoje")
leia (Valor2)
Resultado1 = Valor2-Valor1-1
escreva ("Voce fez no ano pasado: ")
escreva (Resultado1 )
escreva ("Voce vai fazer: ")
Resultado2 = (Valor2-Valor1)+10
escreva (Resultado2)

  }
}
