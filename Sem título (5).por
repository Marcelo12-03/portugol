programa {
  funcao inicio() {
    
    inteiro V = 10

    enquanto (V >= 0) {
    
    escreva (V, "_")
    V = V - 1
    escreva (V, "_")
    V = V - 1
    escreva (V, "_")
    V = V - 1
    escreva (V, "_")
    V = V - 1
    escreva (V, "_")
    V = V - 1
    escreva (V, "_")
    V = V - 1
    
    
    
    
  }
  }
}
